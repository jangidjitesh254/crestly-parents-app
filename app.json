{
  "expo": {
    "name": "Crestly Parents",
    "slug": "crestly-parents",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "crestly-parents",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F25C19",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.crestly.parents"
    },
    "android": {
      "package": "in.crestly.parents",
      "versionCode": 6,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#100D0A"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiBaseUrl": "https://app.crestly.in/api",
      "eas": {
        "projectId": "e44485bb-9158-4e7a-ba74-8df6de582e35"
      }
    },
    "owner": "zitesh"
  }
}
